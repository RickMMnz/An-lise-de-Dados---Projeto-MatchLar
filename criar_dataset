# Converte a lista em uma tabela estruturada

df = pd.DataFrame(data, columns=[
      'cliente_id',
      'imovel_id',
      'preco',
      'bairro',
      'quartos',
      'area_m2',
      'tipo_imovel',
      'visitou',
      'fechou_negocio',
      'tempo_busca_dias',
      'interacoes',
      'preferencia_declarada',
      'nota_satisfacao'
])

